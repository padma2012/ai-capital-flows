{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "dist/index.cjs" },
    { "src": "/assets/(.*)", "dest": "dist/public/assets/$1" },
    { "src": "/(.*)", "dest": "dist/public/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 7 * * *"
    }
  ]
}
